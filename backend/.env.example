# Porta do servidor
PORT=5000

# Ambiente: development | production
NODE_ENV=development

# MongoDB (local ou MongoDB Atlas)
# Local:  mongodb://127.0.0.1:27017/suntrip
# Atlas:  mongodb+srv://<user>:<pass>@cluster.xxxx.mongodb.net/suntrip
MONGODB_URI=mongodb://127.0.0.1:27017/suntrip

# Segredos JWT (troque por valores longos e aleatórios em produção)
JWT_ACCESS_SECRET=troque_este_segredo_de_acesso
JWT_REFRESH_SECRET=troque_este_segredo_de_refresh

# Duração dos tokens
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# Origens permitidas (separadas por vírgula). Vazio = permitir todas (dev)
CORS_ORIGINS=

# --- Envio de email (verificação de conta) ---
# Se estas variáveis estiverem vazias, a verificação de email é ignorada
# (a conta é criada já verificada). Para ativar, preencha com um serviço SMTP.
# Exemplo com Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587,
# SMTP_USER=teu@gmail.com, SMTP_PASS=<palavra-passe de app de 16 dígitos>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=SunTrip <no-reply@suntrip.app>
