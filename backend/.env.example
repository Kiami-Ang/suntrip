# Porta do servidor
PORT=5000

# Ambiente: development | production
NODE_ENV=development

# MongoDB (local ou MongoDB Atlas)
# Local:  mongodb://127.0.0.1:27017/suntrip
# Atlas:  mongodb+srv://<user>:<pass>@cluster.xxxx.mongodb.net/suntrip
MONGODB_URI=mongodb://127.0.0.1:27017/suntrip

# Segredos JWT (troque por valores longos e aleatórios em produção)
JWT_ACCESS_SECRET=troque_este_segredo_de_acesso
JWT_REFRESH_SECRET=troque_este_segredo_de_refresh

# Duração dos tokens
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# Origens permitidas (separadas por vírgula). Vazio = permitir todas (dev)
CORS_ORIGINS=

# --- Envio de email (verificação de conta) ---
# Se nada estiver configurado, a verificação é ignorada (conta criada já verificada).
#
# OPÇÃO RECOMENDADA (funciona no Render grátis): Brevo via API HTTP (porta 443).
# Cria conta em brevo.com, verifica o teu email como remetente e cria uma API Key.
BREVO_API_KEY=
EMAIL_FROM=SunTrip <teu@gmail.com>
#
# OPÇÃO ALTERNATIVA: SMTP (NÃO funciona no Render grátis — SMTP bloqueado).
# Só usar em servidor pago ou local. Ex. Gmail: host smtp.gmail.com, porta 587.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
